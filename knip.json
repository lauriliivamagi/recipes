    },
    "packages/shared/types": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@vitest/coverage-v8",
    "babel-plugin-react-compiler",
    "@mikro-orm/migrations"
  ]
}
