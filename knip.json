{
  "workspaces": {
    "packages/backend": {
      "project": ["src/**/*.ts"],
      "ignore": [
        "src/db/mikro-orm.config.ts",
        "src/db/migrations/**",
        "src/db/orm.ts",
        "src/schemas/**"
      ]
    },
    "packages/frontend": {
