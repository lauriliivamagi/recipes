strict-peer-dependencies=false
auto-install-peers=true

# =============================================================================
# PERFORMANCE
# =============================================================================

# Use locally cached packages, skip network when possible
prefer-offline=true

# Cache native module build results (better-sqlite3, esbuild)
side-effects-cache=true

# =============================================================================
# SUPPLY CHAIN ATTACK MITIGATION
# =============================================================================

# Delay dependency updates by 24 hours (1440 minutes).
# Malware is usually detected quickly — delaying prevents installing
# compromised packages during the detection window.
minimum-release-age=1440

# Warn if trust level has decreased (previously trusted publisher
# now only has provenance or no trust evidence).
# Uses 'audit' instead of 'no-downgrade' because some legacy transitive
# deps (e.g., semver@6.x via eslint-plugin-react) lack provenance.
trust-policy=audit
