# Backend API
API_PORT=8888
API_HOST=0.0.0.0
ALLOWED_ORIGINS=*
LOG_LEVEL=info

# Security
ENABLE_HSTS=false              # Set true in production with HTTPS

# Database (MikroORM + BetterSQLite)
DATABASE_URL=file:./data/app.db

# Frontend
FRONTEND_PORT=3000

# Observability (OpenTelemetry + Jaeger)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
VITE_OTEL_ENABLED=true
VITE_OTEL_EXPORTER_URL=http://localhost:4318/v1/traces
# Jaeger Query API URL (auto-derived from OTEL endpoint if omitted)
# JAEGER_QUERY_URL=http://localhost:16686

# Dev Logger (SQLite-based agent debugging)
DEV_LOGGING=true               # Enable dev logging (auto-disabled in production)
DEV_LOG_DB=.dev-logs/logs.db   # Dev log database path
# DEV_LOG_RETENTION_DAYS=7     # Auto-cleanup after N days
