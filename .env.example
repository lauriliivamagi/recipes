# API keys for AI-powered recipe parsing (used by evals and the Chrome extension).
# The eval script injects these via `infisical run`; for local dev, copy this
# file to .env and fill in the keys you need.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=

# --- Viewer (Vite) ---
# Handle of the public Hob account whose recipes anonymous catalog visitors see.
# Vite picks this up automatically at build/dev time from .env. Must start with VITE_
# to be exposed to client code.
VITE_HOB_DEMO_HANDLE=hob.social

# --- Seed script (packages/build/scripts/seed-pds.ts) ---
# Credentials for publishing in-repo recipe JSON to an ATproto PDS.
# Generate the app password at https://bsky.app/settings/app-passwords
# and name it "Hob Seed" so it can be revoked independently.
HOB_SEED_HANDLE=
HOB_SEED_APP_PASSWORD=
HOB_SEED_PDS_URL=https://bsky.social
