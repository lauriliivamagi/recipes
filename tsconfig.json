{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@recipe/domain/*": ["./packages/domain/src/*"],
      "@recipe/ui/*": ["./packages/ui/src/*"],
      "@recipe/build/*": ["./packages/build/src/*"]
    }
  },
  "include": ["vite-env.d.ts"],
  "exclude": ["node_modules", "site", "packages"]
}
