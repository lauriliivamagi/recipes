{
  "name": "@recipe/atproto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lex:gen": "lex gen-api --yes ./src/generated ../../lexicons/social/hob/temp/*.json"
  },
  "dependencies": {
    "@atproto/api": "^0.19.9",
    "@atproto/lexicon": "^0.6.2",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@atproto/xrpc": "^0.7.7",
    "@recipe/domain": "workspace:*",
    "multiformats": "^13.4.2"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.9.9",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
