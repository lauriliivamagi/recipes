{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable recipe title"
        },
        "slug": {
          "description": "URL-safe identifier, matches the filename without .json",
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "description": "ISO 639-1 two-letter language code"
        },
        "source": {
          "description": "Optional URL of the original recipe",
          "type": "string",
          "pattern": "^https?:\\/\\/"
        },
        "originalText": {
          "type": "string",
          "minLength": 1,
          "description": "Full original recipe text in markdown for side-by-side review"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Categorization tags for filtering and search"
        },
        "servings": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Number of servings the recipe yields"
        },
        "totalTime": {
          "type": "object",
          "properties": {
            "relaxed": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Lower bound (or exact) duration in seconds"
                },
                "max": {
                  "description": "Upper bound duration in seconds",
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "min"
              ],
              "additionalProperties": false,
              "description": "Total time in seconds with all prep front-loaded (relaxed mode)"
            },
            "optimized": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Lower bound (or exact) duration in seconds"
                },
                "max": {
                  "description": "Upper bound duration in seconds",
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "min"
              ],
              "additionalProperties": false,
              "description": "Total time in seconds with prep distributed into idle windows (optimized mode)"
            }
          },
          "required": [
            "relaxed",
            "optimized"
          ],
          "additionalProperties": false
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ],
          "description": "Recipe difficulty level"
        },
        "energyTier": {
          "description": "Derived from DAG decision count + active time",
          "type": "string",
          "enum": [
            "zombie",
            "moderate",
            "project"
          ]
        },
        "notes": {
          "description": "Optional free-form notes about the recipe",
          "type": "string"
        }
      },
      "required": [
        "title",
        "slug",
        "language",
        "originalText",
        "tags",
        "servings",
        "totalTime",
        "difficulty"
      ],
      "additionalProperties": false,
      "description": "Recipe metadata"
    },
    "ingredients": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this ingredient, referenced by operations",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable ingredient name"
          },
          "quantity": {
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "description": "Lower bound (or exact) amount"
              },
              "max": {
                "description": "Upper bound of quantity range",
                "type": "number"
              },
              "unit": {
                "type": "string",
                "minLength": 1,
                "description": "Unit of measurement (metric preferred: g, ml, whole, cloves, etc.)"
              }
            },
            "required": [
              "min",
              "unit"
            ],
            "additionalProperties": false,
            "description": "Amount with unit, optionally a range"
          },
          "group": {
            "type": "string",
            "minLength": 1,
            "description": "Category for shopping list aggregation (e.g., vegetables, meat, dairy)"
          },
          "alternatives": {
            "description": "Substitute ingredients for this slot (each with its own id, name, quantity, group)",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "description": "Unique identifier for this ingredient, referenced by operations",
                  "type": "string",
                  "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Human-readable ingredient name"
                },
                "quantity": {
                  "type": "object",
                  "properties": {
                    "min": {
                      "type": "number",
                      "description": "Lower bound (or exact) amount"
                    },
                    "max": {
                      "description": "Upper bound of quantity range",
                      "type": "number"
                    },
                    "unit": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Unit of measurement (metric preferred: g, ml, whole, cloves, etc.)"
                    }
                  },
                  "required": [
                    "min",
                    "unit"
                  ],
                  "additionalProperties": false,
                  "description": "Amount with unit, optionally a range"
                },
                "group": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Category for shopping list aggregation (e.g., vegetables, meat, dairy)"
                }
              },
              "required": [
                "id",
                "name",
                "group"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "name",
          "group"
        ],
        "additionalProperties": false
      },
      "description": "Ingredients used in this recipe"
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this piece of equipment",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable equipment name"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991,
            "description": "Number of this item needed"
          },
          "capacity": {
            "description": "Physical capacity (e.g., 5L pot, 30cm pan)",
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Capacity value"
              },
              "unit": {
                "type": "string",
                "minLength": 1,
                "description": "Capacity unit (e.g., L, cm)"
              }
            },
            "required": [
              "min",
              "unit"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "name",
          "count"
        ],
        "additionalProperties": false
      },
      "description": "Equipment needed for this recipe"
    },
    "operations": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this operation",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "prep",
              "cook",
              "rest",
              "assemble"
            ],
            "description": "Operation category"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "Verb describing the operation (e.g., dice, sauté, simmer, boil)"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "description": "Ingredient IDs consumed by this operation"
          },
          "depends": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "description": "Operation IDs that must complete before this one"
          },
          "equipment": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "use": {
                  "description": "Equipment ID being used",
                  "type": "string",
                  "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
                },
                "release": {
                  "type": "boolean",
                  "description": "If true, equipment is freed after this operation"
                }
              },
              "required": [
                "use",
                "release"
              ],
              "additionalProperties": false
            },
            "description": "Equipment used by this operation (empty array if none)"
          },
          "time": {
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "minimum": 0,
                "description": "Lower bound (or exact) duration in seconds"
              },
              "max": {
                "description": "Upper bound duration in seconds",
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "min"
            ],
            "additionalProperties": false,
            "description": "Total duration in seconds"
          },
          "activeTime": {
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "minimum": 0,
                "description": "Lower bound (or exact) duration in seconds"
              },
              "max": {
                "description": "Upper bound duration in seconds",
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "min"
            ],
            "additionalProperties": false,
            "description": "Seconds of active attention required"
          },
          "scalable": {
            "type": "boolean",
            "description": "If false, time does not change when scaling servings"
          },
          "temperature": {
            "description": "Target temperature or range",
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "description": "Lower bound (or exact) temperature"
              },
              "max": {
                "description": "Upper bound temperature",
                "type": "number"
              },
              "unit": {
                "type": "string",
                "enum": [
                  "C",
                  "F"
                ],
                "description": "Temperature unit"
              }
            },
            "required": [
              "min",
              "unit"
            ],
            "additionalProperties": false
          },
          "details": {
            "description": "Additional instructions for this operation",
            "type": "string"
          },
          "subProduct": {
            "description": "Sub-product ID this operation contributes to",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "output": {
            "description": "Sub-product ID this operation produces",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "required": [
          "id",
          "type",
          "action",
          "ingredients",
          "depends",
          "equipment",
          "time",
          "activeTime",
          "scalable"
        ],
        "additionalProperties": false
      },
      "description": "Ordered operations forming the recipe DAG"
    },
    "subProducts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier for this sub-product",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable name for the intermediate product"
          },
          "finalOp": {
            "description": "Operation ID that produces this sub-product",
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "required": [
          "id",
          "name",
          "finalOp"
        ],
        "additionalProperties": false
      },
      "description": "Intermediate products created during cooking"
    }
  },
  "required": [
    "meta",
    "ingredients",
    "equipment",
    "operations",
    "subProducts"
  ],
  "additionalProperties": false,
  "description": "Structured recipe data model for the Recipe Visualization App",
  "$id": "https://github.com/lauriliivamagi/recipes/blob/master/config/recipe-schema.json"
}
